{
  "name": "pi-source-drafts",
  "version": "0.1.1",
  "description": "Auto-capture external source information (web search, fetch, user input) as structured Markdown drafts",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-agent",
    "pi-coding-agent",
    "extension",
    "drafts",
    "persistence",
    "source-capture"
  ],
  "author": {
    "name": "pi-source-drafts contributors"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cframe1337/pi-source-drafts.git"
  },
  "homepage": "https://github.com/cframe1337/pi-source-drafts#readme",
  "bugs": {
    "url": "https://github.com/cframe1337/pi-source-drafts/issues"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills/pi-source-drafts/SKILL.md"
    ]
  },
  "files": [
    "src/",
    "skills/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "prepublishOnly": "bun test"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
